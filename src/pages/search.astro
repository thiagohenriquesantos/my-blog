---
import Layout from '@/layouts/Layout.astro'
import SearchComponent from '@/components/Search.astro'
---

<Layout>
  <div class="search-page">
    <h1>Search Posts</h1>
    <SearchComponent />
  </div>
</Layout>

<style>
  .search-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .search-page h1 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2.5rem;
    color: var(--un-preset-theme-colors-primary);
  }
</style>