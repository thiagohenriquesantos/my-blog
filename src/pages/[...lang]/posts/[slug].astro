---
import type { CollectionEntry } from 'astro:content'
import type { Language } from '@/i18n/config'
import { getCollection, render } from 'astro:content'
import Comment from '@/components/Comment/Index.astro'
import PostDate from '@/components/PostDate.astro'
import TagList from '@/components/TagList.astro'
import BackButton from '@/components/Widgets/BackButton.astro'
import TOC from '@/components/Widgets/TOC.astro'
import { allLocales, defaultLocale } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'
import { checkPostSlugDuplication, getPostSlug } from '@/utils/content'
import { getPostDescription } from '@/utils/description'

export async function getStaticPaths() {
  const posts: CollectionEntry<'posts'>[] = await getCollection('posts')

  // Check if there are duplicate post slugs
  const duplicates = await checkPostSlugDuplication(posts)
  if (duplicates.length > 0) {
    throw new Error(`Duplicate post slugs:\n${duplicates.join('\n')}`)
  }

  // >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  // Build a map of post slugs to their supported languages
  // Handles both specific language posts (e.g., 'en') and universal posts (lang: '')
  
  // Step 1: Group posts that are translations of each other
  // Posts with the same ID base (excluding -pt suffix) or with abbrlinkTranslations are related
  const postGroups = new Map<string, CollectionEntry<'posts'>[]>()
  
  for (const post of posts) {
    let groupKey = post.id
    // For PT posts, try to find a matching EN post
    if (post.id.endsWith('-pt')) {
      const baseName = post.id.slice(0, -3)
      const hasEnglishVersion = posts.some(p => p.id === baseName)
      if (hasEnglishVersion) {
        groupKey = baseName
      }
    }
    
    if (!postGroups.has(groupKey)) {
      postGroups.set(groupKey, [])
    }
    postGroups.get(groupKey)!.push(post)
  }
  
  // Step 2: Build slugToLangs map
  const slugToLangsMap = new Map<string, Set<Language>>()
  
  for (const [, postGroup] of postGroups) {
    // Collect all languages in this group
    const supportedLangs = new Set<Language>()
    const allSlugs = new Set<string>()
    
    for (const post of postGroup) {
      const postLang = (post.data.lang || defaultLocale) as Language
      supportedLangs.add(postLang)
      
      // Add the slug for this post's language
      const slug = getPostSlug(post, postLang)
      allSlugs.add(slug)
      
      // Add translated slugs
      if (post.data.abbrlinkTranslations) {
        for (const translatedSlug of Object.values(post.data.abbrlinkTranslations)) {
          allSlugs.add(translatedSlug)
        }
      }
    }
    
    // Map all slugs to the common set of supported languages
    for (const slug of allSlugs) {
      if (!slugToLangsMap.has(slug)) {
        slugToLangsMap.set(slug, new Set())
      }
      for (const lang of supportedLangs) {
        slugToLangsMap.get(slug)!.add(lang)
      }
    }
  }

  // Convert the map to a sorted record for the component props
  // Ensure languages are always sorted by the order defined in config
  const slugToLangs: Record<string, Language[]> = {}
  for (const [slug, langs] of slugToLangsMap) {
    slugToLangs[slug] = [...langs].sort((a, b) => allLocales.indexOf(a) - allLocales.indexOf(b))
  }
  // >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

  return allLocales.flatMap(lang => posts
    // Show drafts in dev mode only
    .filter(post => import.meta.env.DEV || !post.data.draft)
    // Match current language or universal posts
    .filter(post => post.data.lang === lang || post.data.lang === '')
    .map((post) => {
      const slug = getPostSlug(post, lang as Language)
      return {
        params: { lang: getLangRouteParam(lang), slug },
        props: { post, supportedLangs: slugToLangs[slug] },
      }
    }),
  )
}

interface Props {
  post: CollectionEntry<'posts'>
  supportedLangs: Language[]
}

const { post, supportedLangs } = Astro.props
const currentLang = getLangFromLocale(Astro.currentLocale)
const slug = getPostSlug(post, currentLang)
const description = getPostDescription(post, 'meta')
const { Content, headings, remarkPluginFrontmatter } = await render(post)
---

<Layout
  postTitle={post.data.title}
  postDescription={description}
  postSlug={post.id}
  supportedLangs={supportedLangs}
>
  <article class="heti">
    <div class="relative">
      <!-- Go Back Button On Desktop -->
      <BackButton />
      <!-- Title -->
      <h1 class="post-title">
        <span
          transition:name={`post-${slug}${currentLang ? `-${currentLang}` : ''}`}
          data-disable-theme-toggle-transition
        >
          {post.data.title}
        </span>
      </h1>
    </div>

    <!-- Date -->
    <div
      id="post-date"
      class="mb-17.2 block c-primary font-time"
      transition:name={`time-${slug}${currentLang ? `-${currentLang}` : ''}`}
      data-disable-theme-toggle-transition
    >
      <PostDate
        date={post.data.published}
        updatedDate={post.data.updated}
        minutes={remarkPluginFrontmatter.minutes}
      />
    </div>
    <!-- TOC -->
    {post.data.toc && <TOC headings={headings} />}
    <!-- Content -->
    <div id="post-content">
      <Content />
      <!-- Copyright -->
      <div id="post-copyright" />
      <!-- Tag List -->
      {post.data.tags?.length > 0 && (
        <div class="mt-12.6 uno-decorative-line" />
        <TagList
          tags={post.data.tags}
          lang={currentLang}
        />
      )}
      <!-- Comment -->
      <Comment />
    </div>
  </article>
</Layout>
