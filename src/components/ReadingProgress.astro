---
// Reading Progress Indicator Component
---

<div id="reading-progress" class="reading-progress">
  <div class="reading-progress-bar"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.querySelector('.reading-progress-bar')
    const progressContainer = document.getElementById('reading-progress')

    if (!progressBar || !progressContainer) return

    const content = document.getElementById('post-content')
    if (!content) return

    function getContentBounds() {
      // Use offsetTop for stable measurements across browsers.
      const top = (content as HTMLElement).offsetTop
      const height = (content as HTMLElement).scrollHeight
      return { top, height }
    }

    function updateProgress() {
      const { top, height } = getContentBounds()
      const viewport = window.innerHeight

      // Progress is based on scrolling through the article content.
      const start = top
      const end = Math.max(top + height - viewport, start + 1)
      const current = window.scrollY

      const ratio = (current - start) / (end - start)
      const clamped = Math.min(1, Math.max(0, ratio))
      ;(progressBar as HTMLElement).style.width = `${(clamped * 100).toFixed(2)}%`
    }

    // Throttle scroll events for better performance
    let ticking = false
    function handleScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateProgress()
          ticking = false
        })
        ticking = true
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true })
    window.addEventListener('resize', handleScroll, { passive: true })
    updateProgress() // Initial call
  })
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: 1000;
    pointer-events: none;
  }

  .reading-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--un-preset-theme-colors-primary), var(--un-preset-theme-colors-primary));
    width: 0%;
    transition: width 0.1s ease-out;
  }

  /* Hide on mobile for better UX */
  @media (max-width: 768px) {
    .reading-progress {
      display: none;
    }
  }
</style>