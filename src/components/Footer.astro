---
import { themeConfig } from '@/config'
import { getLangFromPath } from '@/i18n/lang'
import { getLocalizedPath } from '@/i18n/path'

const { author } = themeConfig.site
const { links, startYear } = themeConfig.footer

const currentYear = new Date().getFullYear()
const year = Number(startYear) === currentYear
  ? startYear
  : `${startYear}-${currentYear}`

const currentLang = getLangFromPath(Astro.url.pathname)
const socialLinks = links.map(({ name, url }) => {
  const isRSS = url === '/atom.xml' || url === '/rss.xml'
  const isEmail = /^[\w.-]+@[\w.-]+\.[a-z]{2,}$/i.test(url)

  // Define aria-label based on link type
  let ariaLabel = ''
  if (isRSS) {
    ariaLabel = 'Subscribe to RSS feed'
  }
 else if (isEmail) {
    ariaLabel = 'Send email'
  }
 else {
    const ariaLabels: Record<string, string> = {
      GitHub: 'Visit my GitHub profile',
      X: 'Follow me on X (Twitter)',
      Instagram: 'Follow me on Instagram',
      Email: 'Send me an email',
    }
    ariaLabel = ariaLabels[name] || `Visit ${name}`
  }

  if (isRSS) {
    const localizedPath = getLocalizedPath(url, currentLang)
    const href = import.meta.env.DEV
      ? localizedPath
      : localizedPath.slice(0, -1)

    return {
      name,
      href,
      'target': '_blank',
      'rel': 'noopener noreferrer',
      'aria-label': ariaLabel,
    }
  }

  if (isEmail) {
    const href = `mailto:${url}`
    return {
      name,
      href,
      'data-umami-event': 'outbound-link-click',
      'data-umami-event-url': href,
      'aria-label': ariaLabel,
    }
  }

  return {
    name,
    'href': url,
    'target': '_blank',
    'rel': 'noopener noreferrer',
    'data-umami-event': 'outbound-link-click',
    'data-umami-event-url': url,
    'aria-label': ariaLabel,
  }
})
---

<footer class="site-footer">
  <nav class="site-footer__social" aria-label="Social links">
    {socialLinks.map((link, index) => (
      <>
        <a class="site-footer__link highlight-hover" {...link}>{link.name}</a>
        {index < socialLinks.length - 1 && <span class="site-footer__separator" aria-hidden="true">/</span>}
      </>
    ))}
  </nav>

  <p class="site-footer__copyright">
    © {year} {author}
  </p>

  <p class="site-footer__meta">
    Powered by <a class="site-footer__link highlight-hover" href="https://astro.build/" target="_blank" rel="noopener noreferrer" data-umami-event="outbound-link-click" data-umami-event-url="https://astro.build/">Astro</a> and <a class="site-footer__link highlight-hover" href="https://github.com/radishzzz/astro-theme-retypeset" target="_blank" rel="noopener noreferrer" data-umami-event="outbound-link-click" data-umami-event-url="https://github.com/radishzzz/astro-theme-retypeset">Retypeset</a>
  </p>
</footer>

<style>
  .site-footer {
    margin-top: 4.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    color: var(--text-subtle);
    font-family: var(--font-sans);
    font-size: var(--step--2);
    line-height: 1.5;
    text-align: center;
  }

  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.65rem;
    margin-bottom: 0.85rem;
  }

  .site-footer__link {
    color: var(--text-muted);
    padding: 0.15rem 0;
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .site-footer__link::after {
    bottom: 0.18em;
  }

  .site-footer__link:hover {
    color: var(--text-color);
  }

  .site-footer__separator {
    color: var(--text-subtle);
    opacity: 0.55;
  }

  .site-footer__copyright,
  .site-footer__meta {
    margin: 0.35rem 0 0;
  }

  @media (min-width: 768px) {
    .site-footer {
      margin-top: 5.5rem;
      padding-top: 2.25rem;
    }
  }
</style>
