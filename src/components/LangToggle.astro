---
// LangToggle.astro
// Language toggle (EN/PT) with support for post-specific translations.
// Uses supportedLangs prop to determine available translations for the current post.

import { getNextLangPath } from '@/i18n/path'
import type { Language } from '@/i18n/config'

interface Props {
  supportedLangs?: Language[]
}

const { supportedLangs = [] } = Astro.props

const currentPathname = Astro.url.pathname

// Determine current language from pathname
const isPortuguesePath =
  currentPathname === '/pt'
  || currentPathname === '/pt/'
  || currentPathname.startsWith('/pt/')

const currentLang = isPortuguesePath ? 'pt' : 'en'

// If supportedLangs is provided, use it to determine available languages
// Otherwise, fall back to showing both EN and PT
const hasMultipleLangs = supportedLangs.length > 1
const showEn = hasMultipleLangs ? supportedLangs.includes('en') : true
const showPt = hasMultipleLangs ? supportedLangs.includes('pt') : true

// Get the correct href for each language using the translation function
const enHref = showEn ? await getNextLangPath(currentPathname, currentLang as Language, 'en') : null
const ptHref = showPt ? await getNextLangPath(currentPathname, currentLang as Language, 'pt') : null

const isEnglish = currentLang === 'en'
const isPortuguese = currentLang === 'pt'
---

<div class="lang-toggle" aria-label="Language switcher">
  {showEn && (
    <a
      href={enHref ?? '#'}
      class:list={['lang-option', isEnglish ? 'is-active' : 'is-inactive', !enHref && 'is-disabled']}
      aria-label="Alternate version in English"
      aria-current={isEnglish ? 'page' : undefined}
      data-disable={!enHref ? 'true' : undefined}
    >
      EN
    </a>
  )}
  {showEn && showPt && <span class="lang-separator" aria-hidden="true">·</span>}
  {showPt && (
    <a
      href={ptHref ?? '#'}
      class:list={['lang-option', isPortuguese ? 'is-active' : 'is-inactive', !ptHref && 'is-disabled']}
      aria-label="Alternate version in Portuguese"
      aria-current={isPortuguese ? 'page' : undefined}
      data-disable={!ptHref ? 'true' : undefined}
    >
      PT
    </a>
  )}
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
  }

  .lang-option {
    display: inline-block;
    padding: 0.2rem 0.25rem;
    text-decoration: none;
    color: var(--un-preset-theme-colors-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: opacity 0.2s ease-out, color 0.2s ease-out;
    border-radius: 0.3rem;
  }

  .lang-option:hover {
    color: var(--un-preset-theme-colors-primary);
  }

  /* Active: high contrast + weight */
  .lang-option.is-active {
    opacity: 1;
    color: var(--un-preset-theme-colors-primary);
    font-weight: 700;
    cursor: default;
  }

  /* Inactive: clearly secondary but clickable */
  .lang-option.is-inactive {
    opacity: 0.5;
  }

  /* Disabled: not clickable, very muted */
  .lang-option.is-disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
  }

  .lang-option:focus-visible {
    outline: 2px solid var(--un-preset-theme-colors-primary);
    outline-offset: 2px;
  }

  .lang-separator {
    opacity: 0.4;
    user-select: none;
  }
</style>