---
// ThemeToggle.astro - Clean, minimalist theme toggle with Moon/Sun icons
// No circular borders, smooth transitions, full accessibility
interface Props {
  lightModeColor?: string
  darkModeColor?: string
}

const { lightModeColor = 'oklch(98% 0.001 0)', darkModeColor = 'oklch(12% 0.01 0)' } = Astro.props
---

<button
  id="theme-toggle-button"
  class="theme-toggle"
  aria-label="Toggle Dark Mode"
  data-light-mode={lightModeColor}
  data-dark-mode={darkModeColor}
  data-theme-toggle
  type="button"
>
  <!-- Moon Icon (shown in light mode) -->
  <svg
    class="theme-icon theme-icon-moon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>

  <!-- Sun Icon (shown in dark mode) -->
  <svg
    class="theme-icon theme-icon-sun"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
</button>

<script is:inline>
  ;(() => {
    function setTheme(isDark, { persist } = { persist: false }) {
      const root = document.documentElement
      root.classList.toggle('dark', isDark)
      if (persist) {
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
      }

      const btn = document.querySelector('[data-theme-toggle]')
      const light = btn && btn.dataset ? btn.dataset.lightMode : null
      const dark = btn && btn.dataset ? btn.dataset.darkMode : null
      const meta = document.head.querySelector('meta[name="theme-color"]')
      if (meta && light && dark) meta.setAttribute('content', isDark ? dark : light)
    }

    function getEffectiveTheme() {
      const saved = localStorage.getItem('theme')
      if (saved === 'dark') return true
      if (saved === 'light') return false
      return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
    }

    function toggle() {
      setTheme(!document.documentElement.classList.contains('dark'), { persist: true })
    }

    // Event delegation survives Astro view-transitions DOM swaps
    document.addEventListener('click', (e) => {
      const target = e.target instanceof Element ? e.target.closest('[data-theme-toggle]') : null
      if (!target) return

      e.preventDefault()

      const reduceMotion = document.documentElement.classList.contains('reduce-motion')
      const supportsVT = typeof document.startViewTransition === 'function'

      if (reduceMotion || !supportsVT) {
        toggle()
        return
      }

      document.documentElement.style.setProperty('view-transition-name', 'theme-toggle-transition')
      const t = document.startViewTransition(toggle)
      t.finished.finally(() => {
        document.documentElement.style.removeProperty('view-transition-name')
      })
    })

    // Keep in sync with system only when user hasn't chosen explicitly
    if (window.matchMedia) {
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (ev) => {
        if (localStorage.getItem('theme')) return
        setTheme(ev.matches)
      })
    }

    // Ensure icons match current state on first load / hard refresh
    setTheme(getEffectiveTheme())
  })()
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--un-preset-theme-colors-secondary);
    transition: color 0.3s ease-out;
    border-radius: 0.375rem;
    position: relative;
  }

  .theme-toggle:hover {
    color: var(--un-preset-theme-colors-primary);
  }

  .theme-toggle:active {
    transform: scale(0.95);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--un-preset-theme-colors-primary);
    outline-offset: 2px;
  }

  .theme-icon {
    width: 1.25rem;
    height: 1.25rem;
    position: absolute;
    opacity: 1;
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  }

  /* Show moon in light mode (no dark class) */
  .theme-icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  /* Hide sun in light mode */
  .theme-icon-sun {
    opacity: 0;
    transform: scale(0.8) rotate(180deg);
  }

  /* In dark mode, hide moon and show sun */
  html.dark .theme-icon-moon {
    opacity: 0;
    transform: scale(0.8) rotate(180deg);
  }

  html.dark .theme-icon-sun {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
</style>