---
import type { Language } from '@/i18n/config'
import Search from '@/components/Search.astro'
import { ui } from '@/i18n/ui'

interface Props {
  lang: Language
}

const { lang } = Astro.props
const currentUI = ui[lang as keyof typeof ui] ?? ui.en
const dialogId = `search-dialog-${lang}`
---

<button
  type="button"
  class="search-button"
  aria-label={currentUI.search}
  aria-haspopup="dialog"
  aria-controls={dialogId}
  data-search-trigger
>
  <svg
    class="search-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
</button>

<dialog id={dialogId} class="search-dialog" aria-labelledby={`${dialogId}-title`} data-search-dialog>
  <div class="search-dialog__inner" data-search-panel>
    <div class="search-dialog__header">
      <h2 id={`${dialogId}-title`} class="search-dialog__title">{currentUI.search}</h2>
      <button type="button" class="search-dialog__close" aria-label={currentUI.searchClose} data-search-close>
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <div class="search-dialog__body">
      <Search
        lang={lang}
        compact={true}
        autofocus={true}
        inputId={`${dialogId}-input`}
        resultsId={`${dialogId}-results`}
      />
    </div>
  </div>
</dialog>

<script is:inline>
  ;(() => {
  function getFocusableElements(container) {
    return [...container.querySelectorAll(
      'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])',
    )].filter(element => element instanceof HTMLElement && !element.hidden)
  }

  function initSearchDialog(dialog) {
    if (!(dialog instanceof HTMLDialogElement) || dialog.dataset.initialized === 'true') return
    dialog.dataset.initialized = 'true'

    const trigger = document.querySelector(`[aria-controls="${dialog.id}"]`)
    const closeButton = dialog.querySelector('[data-search-close]')
    let lastActive = null

    function focusInput() {
      const input = dialog.querySelector('[data-search-input]')
      if (input instanceof HTMLInputElement) {
        input.focus()
        input.select()
      }
    }

    function openDialog() {
      lastActive = document.activeElement
      if (!dialog.open) dialog.showModal()
      requestAnimationFrame(focusInput)
    }

    function closeDialog() {
      if (dialog.open) dialog.close()
    }

    trigger?.addEventListener('click', openDialog)
    closeButton?.addEventListener('click', closeDialog)

    dialog.addEventListener('close', () => {
      if (lastActive instanceof HTMLElement) lastActive.focus()
      lastActive = null
    })

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) closeDialog()
    })

    dialog.addEventListener('keydown', (event) => {
      if (event.key !== 'Tab') return

      const focusable = getFocusableElements(dialog)
      const first = focusable[0]
      const last = focusable[focusable.length - 1]
      if (!first || !last) return

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault()
        last.focus()
      }
      else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault()
        first.focus()
      }
    })

    document.addEventListener('keydown', (event) => {
      const isSearchShortcut = (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k'
      if (!isSearchShortcut) return
      event.preventDefault()
      openDialog()
    })
  }

  function initAllSearchDialogs() {
    document.querySelectorAll('[data-search-dialog]').forEach(initSearchDialog)
  }

  document.addEventListener('astro:page-load', initAllSearchDialogs)
  initAllSearchDialogs()
  })()
</script>

<style>
  .search-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border: 0;
    border-radius: 0.25rem;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s ease-out;
  }

  .search-button:hover {
    color: var(--text-color);
  }

  .search-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .search-dialog {
    width: min(42rem, calc(100vw - 2rem));
    max-width: 42rem;
    max-height: min(44rem, calc(100dvh - 2rem));
    margin: auto;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 0.35rem;
    background: var(--bg-color);
    color: var(--text-color);
    box-shadow: 0 1.5rem 4rem rgb(0 0 0 / 0.28);
  }

  .search-dialog::backdrop {
    background: var(--backdrop-color);
  }

  .search-dialog__inner {
    display: grid;
    max-height: inherit;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .search-dialog__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem 0;
  }

  .search-dialog__title {
    margin: 0;
    color: var(--text-color);
    font-size: var(--step-0);
    font-weight: 600;
    line-height: var(--leading-tight);
  }

  .search-dialog__close {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 0;
    border-radius: 0.25rem;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font: inherit;
    font-size: var(--step-1);
  }

  .search-dialog__close:hover {
    color: var(--text-color);
  }

  .search-dialog__body {
    min-height: 18rem;
    overflow: auto;
    padding: 0.75rem 1.1rem 1.1rem;
  }

  @media (max-width: 520px) {
    .search-dialog {
      width: calc(100vw - 1rem);
      max-height: calc(100dvh - 1rem);
    }
  }
</style>
